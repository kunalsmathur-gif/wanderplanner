# WanderPlan API — Environment Variables
# Copy this file to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
LLM_PROVIDER=groq                          # groq | ollama | mock
OLLAMA_BASE_URL=http://localhost:11434     # local dev only
OLLAMA_MODEL=llama3.2                      # local dev only
LLM_TIMEOUT_SECONDS=20

# ── Qdrant ────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                            # leave blank for self-hosted
QDRANT_COLLECTION_WIKI=wiki
QDRANT_COLLECTION_REDDIT=reddit
QDRANT_COLLECTION_OSM=osm_pois

# ── Embeddings ────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── CORS ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Nominatim (OpenStreetMap geocoding) ───────────────────────────────────
NOMINATIM_USER_AGENT=wanderplan/1.0        # required by Nominatim ToS
NOMINATIM_RATE_LIMIT=1                     # max 1 req/s — do not increase

# ── Ingestion ─────────────────────────────────────────────────────────────
REDDIT_REFRESH_HOURS=6
REDDIT_MIN_SCORE=10
CONTENT_FILTER_LEVEL=strict

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
