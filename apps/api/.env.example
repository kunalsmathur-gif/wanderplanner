# WanderPlan API — Environment Variables
# Copy this file to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini                        # gemini | groq | ollama | mock
GEMINI_API_KEY=AIza...your-key-here        # Google AI Studio key
GEMINI_MODEL=gemini-2.5-flash-lite
LLM_TIMEOUT_SECONDS=90

# Legacy / alternative providers (optional)
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Qdrant ────────────────────────────────────────────────────────────────
# Use :memory: for stateless Railway deployments (data lost on restart)
# Use Qdrant Cloud URL for persistence: https://cloud.qdrant.io
QDRANT_URL=:memory:
QDRANT_API_KEY=                            # leave blank for :memory: or self-hosted
QDRANT_COLLECTION_WIKI=wiki
QDRANT_COLLECTION_REDDIT=reddit
QDRANT_COLLECTION_OSM=osm_pois

# ── Embeddings ────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── CORS ──────────────────────────────────────────────────────────────────
# Add your Vercel deployment URL here (comma-separated)
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# ── Nominatim (OpenStreetMap geocoding) ───────────────────────────────────
NOMINATIM_USER_AGENT=wanderplan/1.0        # required by Nominatim ToS
NOMINATIM_RATE_LIMIT=1                     # max 1 req/s — do not increase

# ── Pexels (destination/day hero photos) ──────────────────────────────────
# Free tier: 200 req/hour, 20,000/month — https://www.pexels.com/api/
# Optional: itinerary generation degrades gracefully (no day photos) if unset.
PEXELS_API_KEY=

# ── Ingestion ─────────────────────────────────────────────────────────────
REDDIT_REFRESH_HOURS=6
REDDIT_MIN_SCORE=10
CONTENT_FILTER_LEVEL=strict

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
