# WanderPlanner API — Environment Variables
# Copy this file to .env and fill in your values.
# Every value below is either optional (blank/default is safe for local dev)
# or clearly marked required. All third-party services referenced here have
# a free tier sufficient for local development and light production use.

# ── LLM ──────────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini                        # gemini | groq | ollama | mock
GEMINI_API_KEY=AIza...your-key-here        # Google AI Studio key — required for gemini provider
GEMINI_MODEL=gemini-2.5-flash-lite
LLM_TIMEOUT_SECONDS=90

# Legacy / alternative providers (optional — only needed if LLM_PROVIDER is set to them)
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Qdrant (vector search) ─────────────────────────────────────────────────
# Use :memory: for stateless Railway deployments (data lost on restart, re-ingested on boot)
# Use Qdrant Cloud (free tier: 1GB cluster) for persistence: https://cloud.qdrant.io
QDRANT_URL=:memory:
QDRANT_API_KEY=                            # leave blank for :memory: or self-hosted
QDRANT_COLLECTION_WIKI=wiki
QDRANT_COLLECTION_REDDIT=reddit
QDRANT_COLLECTION_OSM=osm_pois
QDRANT_COLLECTION_ITINERARY_CACHE=itinerary_cache

# ── Embeddings & Reranking ──────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2   # only loaded if RERANKING_ENABLED=true

# ── Retrieval feature flags ─────────────────────────────────────────────────
HYBRID_SEARCH_ENABLED=true      # BM25 + semantic RRF fusion (docs §3D)
HYDE_ENABLED=true               # hypothetical-document query augmentation (docs §3G)
RERANKING_ENABLED=false         # cross-encoder rerank of merged candidates (docs P3) — CPU-heavier
ITINERARY_CORPUS_RETRIEVAL_ENABLED=true  # few-shot grounding from real traveller itineraries (docs §9)
ITINERARY_CACHE_SCORE_THRESHOLD=0.88

# ── OpenStreetMap (Overpass + Nominatim, both free/keyless) ────────────────
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
OSM_POI_RADIUS_M=5000
OSM_POI_MAX_RESULTS=60
OSM_REFRESH_DAYS=7
OSM_INGEST_DELAY_SECONDS=2.0    # be polite to the free Overpass API between destinations
NOMINATIM_USER_AGENT=wanderplanner/1.0        # required by Nominatim ToS
NOMINATIM_RATE_LIMIT=1                     # max 1 req/s — do not increase

# ── Pexels (destination/day hero photos) ──────────────────────────────────
# Free tier: 200 req/hour, 20,000/month — https://www.pexels.com/api/
# Optional: itinerary generation degrades gracefully (no day photos) if unset.
PEXELS_API_KEY=

# ── Ingestion (Reddit trip-report + itinerary-corpus scrapers) ────────────
REDDIT_REFRESH_HOURS=6
REDDIT_MIN_SCORE=10
CONTENT_FILTER_LEVEL=strict
# Reddit's own read-only JSON endpoints (e.g. reddit.com/r/x.json) are used
# where possible and need no key. If a subreddit requires authenticated
# access, register a free "script" app at https://www.reddit.com/prefs/apps
# and set these (still free, no paid tier):
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=wanderplanner-corpus/1.0

# ── Currency conversion (free, keyless — Frankfurter.app) ──────────────────
# No env var needed: core/currency_convert.py and the dashboard CurrencyWidget
# both call https://api.frankfurter.app directly (free, no API key required).
USD_TO_INR_RATE=87.0            # static fallback used only where a live rate lookup isn't performed

# ── Database ────────────────────────────────────────────────────────────────
# Local dev (recommended, zero setup, free): SQLite —
DATABASE_URL=sqlite+aiosqlite:///./dev.db
DATABASE_SSL_REQUIRE=false
#
# Production (recommended, free tier): Supabase Postgres. Use the "Transaction
# pooler" connection string (port 6543) shown in Supabase → Project Settings →
# Database — it's PgBouncer-backed and safe for Railway's short-lived
# connections; the "Direct connection" (port 5432) works too but can exhaust
# Supabase's free-tier connection limit (60) under concurrent load.
# DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# DATABASE_SSL_REQUIRE=true          # Supabase requires TLS; asyncpg does not negotiate it automatically
#
# Free-tier caveat: Supabase free projects pause after 7 days with zero
# database traffic and need a manual "resume" from the dashboard (or any
# request within that window keeps it warm) — fine for a side project, worth
# knowing before a demo. See docs/system-design.md §8A / TECHNICAL_DOCUMENTATION.md
# "Hosting decision" section for the full write-up.

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production          # REQUIRED in production — app refuses the default in prod (see core/config.py validator)
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_DOMAIN=                             # empty = host-only cookie (fine for same-site local/dev)
COOKIE_SECURE=true                         # set false only for local http:// dev if needed
COOKIE_SAMESITE=lax

# ── Google SSO (optional — sign-in with Google) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

FRONTEND_BASE_URL=http://localhost:3000     # used to build password-reset / email links

# ── Email (Resend — free tier: 100 emails/day, 3,000/month) ───────────────
# Password reset, admin-request notifications, etc. degrade to a dev-log
# fallback (email content printed to server logs, no send) if unset.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=Wanderplanner <no-reply@wanderplanner.app>
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
